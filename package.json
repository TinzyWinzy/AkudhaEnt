  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:server": "tsx watch server/index.ts",
    "dev:all": "node -e \"const{spawn}=require('child_process');spawn('npx',['vite','--port=3000','--host=0.0.0.0'],{stdio:'inherit',shell:true});spawn('npx',['tsx','watch','server/index.ts'],{stdio:'inherit',shell:true});\"",
    "build": "vite build",
    "preview": "vite preview",
    "server": "tsx server/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
